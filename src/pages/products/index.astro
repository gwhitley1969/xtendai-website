---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { Image } from 'astro:assets';
import bartenderIcon from '../../assets/my-ai-bartender-icon.png';

const title = 'Products | Xtend-AI';
const description = 'Explore mobile apps from Xtend-AI. Discover My AI Bartender and our upcoming photo sharing app, Clique Pix.';
---

<BaseLayout title={title} description={description}>
  <Header slot="header" />

  <!-- Page Header -->
  <section class="page-header">
    <div class="page-header__bg">
      <div class="page-header__glow"></div>
    </div>
    <div class="container">
      <span class="badge">Our Products</span>
      <h1>AI-powered apps for <span class="text-gradient">real life</span></h1>
      <p class="page-header__subtitle">Discover mobile experiences designed for discovery</p>
    </div>
  </section>

  <!-- Featured Product -->
  <section class="section">
    <div class="container">
      <div class="product-card product-card--featured">
        <div class="product-card__glow"></div>
        <div class="product-card__content">
          <span class="badge badge--gold">Available Now!!!</span>
          <div class="product-card__heading">
            <div class="product-card__icon">
              <Image
                src={bartenderIcon}
                alt=""
                width={72}
                height={72}
                densities={[2, 3]}
                loading="eager"
              />
            </div>
            <h2 class="product-card__title">My AI Bartender</h2>
          </div>
          <p class="product-card__description">
            Your personal AI bartender that helps you discover cocktails, make smarter substitutions,
            and use what you already have. Chat with your bartender, talk hands-free, scan your home bar,
            and refine your own creations.
          </p>
          <div class="product-card__features">
            <span class="product-card__feature">💬 Chat</span>
            <span class="product-card__feature">🎙️ Voice</span>
            <span class="product-card__feature">📷 Scan My Bar</span>
            <span class="product-card__feature">✨ Create</span>
            <span class="product-card__feature">🔗 Share</span>
          </div>
          <a href="/products/my-ai-bartender" class="btn btn--primary btn--large">
            Learn More
            <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
              <path d="M4 10H16M16 10L11 5M16 10L11 15" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Coming Soon Section -->
  <section class="section section--glow" id="coming-soon">
    <div class="container">
      <div class="section-header text-center">
        <span class="badge">Coming Soon</span>
        <h2>More experiences in development</h2>
      </div>

      <div class="coming-soon-card card card--glow">
        <img
          src="/images/cliquepix-logo.png"
          alt="Clique Pix logo"
          class="coming-soon-card__logo"
        />
        <h3>Clique Pix</h3>
        <p>
          Private, event-based group photo sharing. Create temporary Events or
          persistent Cliques, snap and share photos and videos in real time, and let
          everything disappear when the moment's over.
        </p>
      </div>

      <div class="section__cta text-center">
        <p>Interested in partnering with us on upcoming products?</p>
        <a href="/contact" class="btn btn--secondary btn--large">Get in Touch</a>
      </div>
    </div>
  </section>

  <Footer slot="footer" />
</BaseLayout>

<style>
  .page-header {
    position: relative;
    padding: var(--space-20) 0;
    text-align: center;
    overflow: hidden;
  }

  .page-header__bg {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .page-header__glow {
    position: absolute;
    top: -100px;
    left: 50%;
    transform: translateX(-50%);
    width: 600px;
    height: 400px;
    background: radial-gradient(ellipse at center, rgba(24, 140, 255, 0.15) 0%, transparent 70%);
  }

  .page-header .container {
    position: relative;
    z-index: 1;
  }

  .page-header h1 {
    margin: var(--space-4) 0;
    font-size: clamp(2.5rem, 6vw, 4rem);
  }

  .page-header__subtitle {
    font-size: 1.25rem;
    color: var(--xt-text-secondary);
    margin: 0;
  }

  .section-header {
    margin-bottom: var(--space-12);
  }

  .section-header h2 {
    margin-top: var(--space-4);
  }

  .section__cta {
    margin-top: var(--space-12);
  }

  .section__cta p {
    margin-bottom: var(--space-4);
  }

  /* Product Cards */
  .product-card--featured {
    position: relative;
    background: linear-gradient(135deg, rgba(24, 140, 255, 0.2) 0%, rgba(59, 130, 246, 0.1) 100%);
    border: 1px solid rgba(24, 140, 255, 0.3);
    border-radius: var(--radius-xl);
    padding: var(--space-12);
    overflow: hidden;
  }

  .product-card__glow {
    position: absolute;
    top: 0;
    right: 0;
    width: 400px;
    height: 400px;
    background: radial-gradient(circle at center, rgba(24, 140, 255, 0.2) 0%, transparent 70%);
    pointer-events: none;
  }

  .product-card__content {
    position: relative;
    z-index: 1;
    max-width: 700px;
  }

  .product-card__title {
    font-size: clamp(2rem, 5vw, 3rem);
    margin: var(--space-4) 0;
  }

  .product-card__heading {
    display: flex;
    align-items: center;
    gap: var(--space-4);
    margin: var(--space-4) 0;
  }

  .product-card__heading .product-card__title {
    margin: 0;
  }

  .product-card__icon {
    width: 72px;
    height: 72px;
    flex-shrink: 0;
  }

  .product-card__icon :global(img) {
    width: 100%;
    height: 100%;
    display: block;
    border-radius: 22%;
    box-shadow: 0 6px 20px rgba(0, 0, 0, 0.3);
  }

  .product-card__description {
    font-size: 1.125rem;
    line-height: 1.8;
    margin-bottom: var(--space-6);
  }

  .product-card__features {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    margin-bottom: var(--space-8);
  }

  .product-card__feature {
    padding: var(--space-2) var(--space-4);
    font-size: 0.9375rem;
    font-weight: 500;
    background: rgba(255, 255, 255, 0.1);
    border-radius: 100px;
    color: var(--xt-text-primary);
  }

  /* Cards */
  .card .icon-circle {
    margin-bottom: var(--space-4);
    font-size: 1.5rem;
  }

  .card h3 {
    margin-bottom: var(--space-3);
  }

  /* Coming Soon Card - single centered */
  .coming-soon-card {
    max-width: 600px;
    margin: 0 auto;
    text-align: center;
  }

  .coming-soon-card__logo {
    display: block;
    max-width: 160px;
    height: auto;
    margin: 0 auto var(--space-4);
  }
</style>
